# Copy to .env and fill in your values
APP_NAME=E-Commerce Recommendation Engine
APP_VERSION=1.0.0
DEBUG=false

MONGODB_URL=mongodb://mongo:27017
MONGODB_DB=recommendation_engine

REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL=300

MODEL_PATH=training/models/recommender_model.pkl
TOP_N_RECOMMENDATIONS=10

AB_TEST_SPLIT=0.5
